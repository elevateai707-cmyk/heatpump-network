# === Database ===
# PostgreSQL (production)
DATABASE_URL="postgresql://user:password@localhost:5432/heatpump_network"

# SQLite (development)
# DATABASE_URL="file:./dev.db"

# === NextAuth ===
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# === Auth Providers ===
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# === Email (Resend) ===
RESEND_API_KEY="re_xxxxx"
EMAIL_FROM="noreply@heatpumpnetwork.com"

# === Meilisearch ===
MEILISEARCH_HOST="http://localhost:7700"
MEILI_MASTER_KEY="masterKey"

# === Stripe ===
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxxx"
STRIPE_SECRET_KEY="sk_test_xxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxx"

# === Mapbox ===
NEXT_PUBLIC_MAPBOX_TOKEN="pk.xxxx"

# === Supabase (File Storage) ===
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJxxxx"
SUPABASE_SERVICE_ROLE_KEY="eyJxxxx"

# === Site ===
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Heat Pump Network"

# === Agent Chat (shared @agentic/agent-core) ===
# Server-only model API key — NEVER exposed to the browser (read by createProvider on the server).
AI_API_KEY="your-nous-api-key"
AI_PROVIDER="nous"
# Model id REQUIRES the provider prefix (e.g. 'deepseek/...').
AI_PRIMARY_MODEL="deepseek/deepseek-v4-flash"

# === Lead Credit Pricing (per lead) ===
LEAD_CREDIT_PRICE_CENTS=5000  # $50 per lead credit

# === Premium Subscription Pricing ===
PREMIUM_MONTHLY_PRICE_CENTS=9900  # $99/mo

# === Sponsored Placement Pricing ===
SPONSORED_MONTHLY_PRICE_CENTS=29900  # $299/mo per city/category

# --- AI provider chain ---
# Primary provider for /api/agent. anthropic = Claude (paid, reliable);
# nous = Nous Portal deepseek (cheap/free). AI_FALLBACK_* is optional: on any
# primary error the turn retries on the fallback backend with AI_FALLBACK_MODEL.
AI_PROVIDER=anthropic
AI_API_KEY=sk-ant-...
AI_PRIMARY_MODEL=claude-haiku-4-5
AI_FALLBACK_PROVIDER=nous
AI_FALLBACK_API_KEY=sk-nous-...
AI_FALLBACK_MODEL=deepseek/deepseek-v4-flash
